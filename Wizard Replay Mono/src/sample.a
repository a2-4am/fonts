!cpu 6502
!to "build/SAMPLE.SYSTEM#FF2000",plain
*=$2000

         !source "../common/src/constants.a"    ; no code
         !source "../common/src/macros.a"       ; no code

         +READ_ROM_NO_WRITE
         sta   PRIMARYCHARSET
         sta   CLR80VID
         sta   STOREOFF
         sta   READMAINMEM
         sta   WRITEMAINMEM
         jsr   ROM_TEXT
         jsr   ROM_HOME
         jsr   ROM_NORMAL
         jsr   ROM_IN0
         jsr   ROM_PR0
         +BUILD_HGR_LOOKUP_TABLES HGRLO, HGRHI

         ; relocate program code
-        inc   FM+2
         inc   FMDEST+2
         lda   FM+2
         cmp   #>LastMover
         bcc   -
         ldx   #0
FM       lda   FirstMover, x
FMDEST   sta   RELOC, x
         inx
         bne   FM
         dec   FM+2
         dec   FMDEST+2
         lda   FMDEST+2
         cmp   #>RELOC
         bcs   FM

         jmp   Start

FirstMover
!pseudopc RELOC {
Start
         jsr   Home
         lda   #0
         sta   STRINGINDEX
PrintLoop
         ldx   STRINGINDEX
         lda   StringPointers, x
         inx
         ldy   StringPointers, x
         beq   PrintDone
         inx
         stx   STRINGINDEX
         ldx   #0
         jsr   DrawString
         inc   VTAB
         bne   PrintLoop             ; always branches
PrintDone
         +DEBUGWAIT
         jsr   PRODOS_MLI
         !byte $65
         !word +
+        !byte 4

s_header1
         +PSTRING "WIZARD REPLAY MONO       (C) 2025 BY 4AM"
s_blank
         !byte 0
s_header2
         +PSTRING "A STANDARD-SIZED UPPERCASE PIXEL FONT"
s_header3
         +PSTRING "FOR THE APPLE ][ HI-RES GRAPHICS SCREEN"
s_sample1
         +PSTRING "PACK MY BOX WITH FIVE DOZEN LIQUOR JUGS."
s_sample2
         +PSTRING "JACKDAWS LOVE MY BIG SPHINX OF QUARTZ"
s_sample3
         +PSTRING "SPHINX OF BLACK QUARTZ, JUDGE MY VOW!"
s_sample4
         +PSTRING "THE FIVE BOXING WIZARDS JUMP QUICKLY"
s_sample5
         +PSTRING "HOW QUICKLY DAFT JUMPING ZEBRAS VEX"
s_sample6
         +PSTRING "GLIB JOCKS QUIZ NYMPH TO VEX DWARF"
s_alpha_upper
         +PSTRING "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
s_alpha_lower
         +PSTRING "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
s_numerals
         +PSTRING "1234567890@#$%^&*()-=_+[]\\;':\",./<>?!"
s_lorem_1
         +PSTRING "LOREM IPSUM DOLOR SIT AMET, CONSECTETUR"
s_lorem_2
         +PSTRING "ADIPISCING ELIT, SED DO EIUSMOD TEMPOR"
s_lorem_3
         +PSTRING "INCIDIDUNT UT LABORE ET DOLORE MAGNA"
s_lorem_4
         +PSTRING "ALIQUA. LACUS VEL FACILISIS VOLUTPAT EST"
s_lorem_5
         +PSTRING "VELIT EGESTAS DUI ID. ORNARE MASSA EGET"
s_lorem_6
         +PSTRING "EGESTAS PURUS VIVERRA ACCUMSAN IN NISL"
s_lorem_7
         +PSTRING "NISI. ID VENENATIS A CONDIMENTUM VITAE."
s_lorem_8
         +PSTRING "IMPERDIET NULLA MALESUADA PELLENTESQUE"

StringPointers
         !word s_header1
         !word s_blank
         !word s_header2
         !word s_header3
         !word s_blank
         !word s_sample1
         !word s_sample2
         !word s_sample3
         !word s_sample4
         !word s_sample5
         !word s_sample6
         !word s_blank
         !word s_alpha_upper
         !word s_alpha_lower
         !word s_numerals
         !word s_blank
         !word s_lorem_1
         !word s_lorem_2
         !word s_lorem_3
         !word s_lorem_4
         !word s_lorem_5
         !word s_lorem_6
         !word s_lorem_7
         !word s_lorem_8
         !word 0

         !source "../common/src/ui.common.a"
         !source "src/ui.font.a"
         !source "src/ui.font.data.a"
}
LastMover
